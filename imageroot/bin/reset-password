#
# Reset the password of a sam user (any role: admin, auditor, viewer).
# Must be run inside the module environment: runagent -m samN
#
# Usage: reset-password --username USERNAME --password PASSWORD
#

set -e

usage() {
    cat <<EOF
Usage: $(basename "$0") --username USERNAME --password PASSWORD

Reset the password of a sam user account (any role: admin, auditor, viewer).

Required:
  --username USERNAME   Username (e.g. admin)
  --password PASSWORD   New password

Options:
  -h, --help            Show this help message
EOF
}

USERNAME=""
PASSWORD=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --username) USERNAME="$2"; shift 2 ;;
        --password) PASSWORD="$2"; shift 2 ;;
        -h|--help)  usage; exit 0 ;;
        *) echo "Unknown option: $1" >&2; usage; exit 1 ;;
    esac
done

if [[ -z "$USERNAME" || -z "$PASSWORD" ]]; then
    echo "Error: --username and --password are required." >&2
    usage
    exit 1
fi

podman exec sam-app \
    python3 /app/app/manage.py admin reset-password "${USERNAME}" --password "${PASSWORD}"

echo "[reset-password] Password for '${USERNAME}' has been reset successfully."
