set -e -o pipefail
exec 1>&2 # Redirect any output to the journal (stderr)

# Read secrets
source <(grep -v '^#' secrets.env | sed 's/^/export /')

# PostgreSQL runs embedded inside the sam-app container,
# managed by supervisord. Data is stored at /data/pg inside the container.
# We restore by copying the dump into the running container and using
# pg_restore via the UNIX socket at /run/postgresql.

# Restore SSH collector keys and known_hosts
podman cp collector_key     sam-app:/data/keys/collector_key
podman cp collector_key.pub sam-app:/data/keys/collector_key.pub
podman cp known_hosts       sam-app:/data/keys/known_hosts
podman exec sam-app chown nobody:nobody /data/keys/collector_key /data/keys/known_hosts
podman exec sam-app chown root:root /data/keys/collector_key.pub
podman exec sam-app chmod 600 /data/keys/collector_key
podman exec sam-app chmod 644 /data/keys/collector_key.pub /data/keys/known_hosts

# Wait for PostgreSQL to be ready inside the container (supervisord starts it async)
for i in $(seq 1 30); do
    podman exec sam-app \
        su -s /bin/sh postgres -c "pg_isready -h /run/postgresql -q" && break
    sleep 2
done

# Copy the dump file into the container
podman cp sam.pg_dump sam-app:/tmp/sam.pg_dump

# Drop and recreate the database to avoid conflicts, then restore
podman exec sam-app \
    su -s /bin/sh postgres -c \
    "psql -h /run/postgresql -c 'DROP DATABASE IF EXISTS ssh_manager;' \
     && psql -h /run/postgresql -c 'CREATE DATABASE ssh_manager OWNER ssh_manager;'"

podman exec sam-app \
    su -s /bin/sh postgres -c \
    "PGPASSWORD=${POSTGRES_PASSWORD} pg_restore --no-owner --no-privileges \
        -h /run/postgresql \
        -U ssh_manager \
        -d ssh_manager \
        /tmp/sam.pg_dump"

# Clean up
podman exec sam-app rm -f /tmp/sam.pg_dump
rm -f sam.pg_dump collector_key collector_key.pub known_hosts
