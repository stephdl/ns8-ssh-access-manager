{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Configure ssh-access-manager",
    "$id": "http://nethserver.org/json-schema/task/input/ssh-access-manager/configure-module",
    "description": "Configure ssh-access-manager",
    "examples": [
        {
            "host": "sam.domain.org",
            "lets_encrypt": true
        }
    ],
    "type": "object",
    "required": [
        "host"
    ],
    "properties": {
        "host": {
            "type": "string",
            "description": "Host name for the application, like 'sam.domain.org'",
            "format": "hostname",
            "pattern": "\\."
        },
        "lets_encrypt": {
            "type": "boolean",
            "title": "Let's Encrypt certificate",
            "description": "Request a valid Let's Encrypt certificate."
        }
    }
}