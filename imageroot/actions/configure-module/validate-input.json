{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Configure ssh-access-manager",
    "$id": "http://nethserver.org/json-schema/task/input/ssh-access-manager/configure-module",
    "description": "Configure ssh-access-manager",
    "examples": [
        {
            "host": "ssh-access-manager.domain.org",
            "http2https": true,
            "lets_encrypt": true
        }
    ],
    "type": "object",
    "required": [
        "host"
    ],
    "properties": {
        "host": {
            "type": "string",
            "description": "Host name for the application, like 'ssh-access-manager.domain.org'",
            "format": "hostname",
            "pattern": "\\."
        },
        "lets_encrypt": {
            "type": "boolean",
            "title": "Let's Encrypt certificate",
            "description": "Request a valid Let's Encrypt certificate."
        },
        "http2https": {
            "type": "boolean",
            "title": "HTTP to HTTPS redirection",
            "description": "Redirect all the HTTP requests to HTTPS"
        },
        "from": {
            "type": "string",
            "description": "Email address used as sender in the smarthost configuration",
            "anyOf": [
                {"maxLength": 0},
                {"format": "email"}
            ]
        },
        "to": {
            "type": "string",
            "description": "Email address used as recipient in the smarthost configuration",
            "anyOf": [
                {"maxLength": 0},
                {"format": "email"}
            ]
        }
    }
}